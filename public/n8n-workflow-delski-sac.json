          "subject": "=🔔 Novo Chamado: {{ $('Normalizar Dados').item.json.body.protocolo }} - {{ $('Normalizar Dados').item.json.body.assunto }}",
          "htmlContent": "=<div style=\"font-family: Arial, sans-serif; max-width: 500px; margin: 0 auto; padding: 20px;\"><h2 style=\"color: #007bff;\">🔔 Novo Chamado Recebido</h2><table style=\"width:100%; border-collapse: collapse; font-size: 14px;\"><tr><td style=\"padding: 8px; color: #888; width: 120px;\">Protocolo:</td><td style=\"padding: 8px; font-weight: bold; color: #333;\">{{ $('Normalizar Dados').item.json.body.protocolo }}</td></tr><tr style=\"background:#f9f9f9;\"><td style=\"padding: 8px; color: #888;\">Cliente:</td><td style=\"padding: 8px; color: #333;\">{{ $('Normalizar Dados').item.json.body.nome }} ({{ $('Normalizar Dados').item.json.body.empresa }})</td></tr><tr><td style=\"padding: 8px; color: #888;\">E-mail:</td><td style=\"padding: 8px; color: #333;\">{{ $('Normalizar Dados').item.json.body.email }}</td></tr><tr style=\"background:#f9f9f9;\"><td style=\"padding: 8px; color: #888;\">Assunto:</td><td style=\"padding: 8px; color: #333;\">{{ $('Normalizar Dados').item.json.body.assunto }}</td></tr><tr><td style=\"padding: 8px; color: #888;\">Categoria:</td><td style=\"padding: 8px; color: #333;\">{{ $('Normalizar Dados').item.json.body.categoria }}</td></tr><tr style=\"background:#f9f9f9;\"><td style=\"padding: 8px; color: #888;\">Análise IA:</td><td style=\"padding: 8px; color: #333;\">{{ $('Extrair JSON da IA').item.json.ia.sentimento }} · {{ $('Extrair JSON da IA').item.json.ia.urgencia }}</td></tr></table><hr style=\"margin: 20px 0; border: 1px solid #eee;\"><p style=\"color: #888; font-size: 13px; font-weight: bold;\">Descrição:</p><p style=\"color: #333; font-size: 13px; line-height: 1.6;\">{{ $('Normalizar Dados').item.json.body.descricao }}</p><a href=\"http://localhost:3000/chamados\" style=\"display:inline-block; margin-top: 16px; background: #007bff; color: #fff; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold;\">Abrir no Painel ADM</a></div>"
        }
      },
